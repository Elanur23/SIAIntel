  /**
   * Generate article URL
   */
  private generateUrl(article: PublishableArticle): string {
    const baseUrl = process.env.NEXT_PUBLIC_SITE_URL || 'https://siaintel.com'
    return `${baseUrl}/${article.language}/news/${article.id}-${article.slug}`
  }

