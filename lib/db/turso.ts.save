^G Help       ^O Write Out  ^W Where Is   ^K Cut        ^T Execute
^X Exit       ^R Read File  ^\ Replace    ^U Paste      ^J Justifyeclare global {
  // eslint-disable-next-line no-var
  var prisma: PrismaClient | undefined
