let hasLoggedConnection = false

function createPrismaClient(): PrismaClient {
  const tursoUrl = process.env.TURSO_DATABASE_URL
  const tursoAuthToken = process.env.TURSO_AUTH_TOKEN
  const databaseUrl = process.env.DATABASE_URL

  const useTurso =
    process.env.NODE_ENV === 'production' &&
    !!tursoUrl &&
    !!tursoAuthToken

  if (!hasLoggedConnection) {
    console.log(
      useTurso
        ? '[DATABASE] Connecting to Turso LibSQL...'
        : '[DATABASE] Connecting to local SQLite...'
    )
    hasLoggedConnection = true
  }

  if (useTurso) {
    const libsql = createClient({
      url: tursoUrl,
      authToken: tursoAuthToken,
    })

    const adapter = new PrismaLibSQL(libsql)

    return new PrismaClient({
      adapter,
      log: ['error'],
    })
  }

  if (!databaseUrl || !databaseUrl.startsWith('file:')) {
    throw new Error('DATABASE_URL must start with file: in non-production mode')
  }

  return new PrismaClient({
    log: ['error'],
  })
}

export const prisma = global.prisma || createPrismaClient()

if (process.env.NODE_ENV !== 'production') {
  global.prisma = prisma
}

if (typeof process !== 'undefined' && typeof process.on === 'function') {
  process.on('beforeExit', async () => {
    await prisma.$disconnect()
  })
}

export async function checkDatabaseConnection(): Promise<boolean> {
  try {
    await prisma.$queryRaw`SELECT 1`
    return true
  } catch (error) {
    console.error('[DATABASE] Connection failed:', error)
    return false
  }
}

export async function getDatabaseInfo(): Promise<{
  type: 'sqlite' | 'turso'
  connected: boolean
  url?: string
}> {
  const isTurso =
    process.env.NODE_ENV === 'production' &&
    !!process.env.TURSO_DATABASE_URL &&
    !!process.env.TURSO_AUTH_TOKEN

  const connected = await checkDatabaseConnection()

  return {
    type: isTurso ? 'turso' : 'sqlite',
    connected,
    url: isTurso ? process.env.TURSO_DATABASE_URL : process.env.DATABASE_URL,
  }
}
