{
  "name": "siaintel-terminal",
  "version": "1.0.0",
  "description": "SIA Intelligence - Professional AI-Powered Financial Intelligence Terminal",
  "scripts": {
    "dev": "next dev -p 3003",
    "build": "next build",
    "build:production": "npm run validate:env && npm run type-check && next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "sitemap": "next-sitemap",
    "test": "jest",
    "test:sia-news": "jest lib/sia-news/__tests__",
    "test:security": "jest lib/rbac/__tests__",
    "test:security-all": "npx tsx scripts/test-security-features.ts",
    "test:rbac": "jest lib/rbac/__tests__/privilege-escalation.test.ts",
    "test:coverage": "jest --coverage lib/rbac/",
    "worker:audit-cleanup": "npx tsx scripts/start-audit-cleanup-worker.ts",
    "migrate:turso": "npx tsx scripts/migrate-to-turso.ts",
    "verify:production": "npx tsx scripts/verify-production.ts",
    "validate:env": "node -e \"if (!process.env.NEXTAUTH_SECRET) throw new Error('NEXTAUTH_SECRET not set')\"",
    "clean": "scripts\\clean-cache.bat",
    "restart": "scripts\\restart-dev.bat"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@ducanh2912/next-pwa": "^10.2.9",
