    "framer-motion": "^10.18.0",
    "google-auth-library": "^9.15.0",
    "googleapis": "^128.0.0",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.294.0",
    "next": "^14.0.4",
    "next-auth": "^5.0.0-beta.30",
    "next-seo": "^6.4.0",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "openai": "^4.104.0",
    "postcss": "^8.4.32",
    "prisma": "^5.10.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "rss-parser": "^3.13.0",
    "sharp": "^0.33.1",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^3.3.6",
    "telegraf": "^4.12.0",
    "twitter-api-v2": "^1.15.0",
    "typescript": "^5.3.0",
    "zod": "^3.25.76",
    "zustand": "^4.5.7"
