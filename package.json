    "@types/react-dom": "^18.2.18",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.0.4",
    "ioredis": "^5.10.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
