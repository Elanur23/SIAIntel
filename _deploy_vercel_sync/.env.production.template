# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================
# CRITICAL: Copy this file to .env.production and fill in actual values
# NEVER commit .env.production to git!

# ============================================
# 🔐 SECURITY SECRETS (REQUIRED)
# ============================================

# NextAuth Secret - Used for JWT token encryption
# SECURITY: Must be 32+ characters, cryptographically random
# Generate: openssl rand -base64 48
# NEVER use the same value in dev/staging/production
NEXTAUTH_SECRET=REPLACE_WITH_48_CHAR_RANDOM_STRING

# Session Secret - Used for session token generation
# SECURITY: Must be different from NEXTAUTH_SECRET
# Generate: openssl rand -base64 48
SESSION_SECRET=REPLACE_WITH_48_CHAR_RANDOM_STRING

# Admin Password - Initial admin account password
# SECURITY: Min 16 characters, mix of upper/lower/numbers/special
# Generate: openssl rand -base64 32
ADMIN_SECRET=REPLACE_WITH_32_CHAR_RANDOM_STRING

# NextAuth URL - Your production domain
NEXTAUTH_URL=https://your-domain.com

# Node Environment - MUST be 'production'
NODE_ENV=production

# ============================================
# 🗄️ DATABASE - TURSO (REQUIRED)
# ============================================

# Turso Database URL
# Format: libsql://[db-name]-[org].turso.io
# Get from: turso db show [db-name] --url
TURSO_DATABASE_URL=libsql://your-db-name-org.turso.io

# Turso Auth Token
# Get from: turso db tokens create [db-name]
# SECURITY: Keep this secret, it grants full database access
TURSO_AUTH_TOKEN=eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9.REPLACE_WITH_YOUR_TOKEN

# Combined Database URL (used by Prisma)
# Format: libsql://[url]?authToken=[token]
DATABASE_URL=${TURSO_DATABASE_URL}?authToken=${TURSO_AUTH_TOKEN}

# ============================================
# 🔴 REDIS - UPSTASH (REQUIRED for BullMQ)
# ============================================

# Upstash Redis URL
# Format: rediss://default:[password]@[endpoint].upstash.io:6379
# Get from: https://console.upstash.com/redis
REDIS_URL=rediss://default:REPLACE_WITH_PASSWORD@REPLACE_WITH_ENDPOINT.upstash.io:6379

# Alternative: Redis Cloud or Self-Hosted
# REDIS_URL=redis://default:password@your-redis-host:6379

# Redis Connection Details (optional, extracted from REDIS_URL)
REDIS_HOST=your-endpoint.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# ============================================
# 📢 ALERTING - SLACK (REQUIRED for audit logs)
# ============================================

# Slack Webhook URL for security alerts
# Get from: Slack Workspace Settings → Apps → Incoming Webhooks
# Used for: Audit log cleanup notifications, security alerts
SLACK_WEBHOOK_URL=[MASKED_SECRET]

# ============================================
# 📱 TELEGRAM (OPTIONAL - for security alerts)
# ============================================

# Telegram Bot Token
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram Chat ID for alerts
# Get from: @userinfobot on Telegram
TELEGRAM_ALERT_CHAT_ID=-1001234567890

# ============================================
# 🤖 AI SERVICES (REQUIRED)
# ============================================

