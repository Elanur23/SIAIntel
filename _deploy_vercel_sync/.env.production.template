# Google Indexing API (optional)
GOOGLE_INDEXING_CLIENT_EMAIL=indexing@your-project.iam.gserviceaccount.com
GOOGLE_INDEXING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ============================================
# 🌐 SITE CONFIGURATION
# ============================================

SITE_URL=https://your-domain.com
SITE_NAME=SIA Intelligence Terminal
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# ============================================
# 🔧 OPTIONAL SERVICES
# ============================================

# Discord Webhook (for distribution)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXXXX/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Twitter/X API (for distribution)
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret

# Email (SendGrid or SMTP)
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@your-domain.com
SMTP_PASS=your_app_password

# ============================================
# 🛡️ SECURITY CONFIGURATION
# ============================================

# Idle Timeout (minutes)
IDLE_TIMEOUT_MINUTES=30

# Rate Limiting
RATE_LIMIT_WINDOW=60000
MAX_REQUESTS_PER_WINDOW=100

# CSRF Protection
CSRF_SECRET=REPLACE_WITH_32_CHAR_RANDOM_STRING

# ============================================
# 📈 PERFORMANCE & CDN
# ============================================

# CDN URLs (if using external CDN)
NEXT_PUBLIC_CDN_AUDIO_URL=https://cdn.your-domain.com/audio
NEXT_PUBLIC_CDN_IMAGES_URL=https://cdn.your-domain.com/images
NEXT_PUBLIC_CDN_STATIC_URL=https://cdn.your-domain.com/static
NEXT_PUBLIC_CDN_VIDEO_URL=https://cdn.your-domain.com/video

# ISR Configuration
ISR_MEMORY_CACHE_SIZE=52428800
ISR_FLUSH_TO_DISK=true
REVALIDATION_SECRET=REPLACE_WITH_32_CHAR_RANDOM_STRING

# ============================================
# 🚀 VERCEL CONFIGURATION (if using Vercel)
# ============================================

# These are automatically set by Vercel, no need to add manually:
# VERCEL=1
# VERCEL_ENV=production
# VERCEL_URL=your-project.vercel.app
# VERCEL_GIT_COMMIT_SHA=abc123...

# ============================================
# 📝 NOTES
# ============================================

# 1. Generate secure secrets:
#    openssl rand -base64 48
#
# 2. Never commit this file to git:
#    Add .env.production to .gitignore
#
# 3. Use different secrets for each environment:
#    dev, staging, production should have unique values
#
# 4. Rotate secrets every 90 days
#
# 5. Store backup of secrets in secure vault:
#    1Password, AWS Secrets Manager, or similar
#
# 6. Test all connections before going live:
#    npm run verify:production
