# SOVEREIGN V14 - THE FACTORY
# Environment Configuration

# ============================================================================
# GEMINI API
# ============================================================================
GEMINI_API_KEY=your_gemini_api_key_here

# Model Selection: 'pro', 'flash', or '2.5-pro' (recommended)
GEMINI_MODEL_TYPE=2.5-pro

# ============================================================================
# RATE LIMITING
# ============================================================================

# Base delay between API requests (seconds)
RATE_LIMIT_DELAY=45

# Retry delay for 429 rate limit errors (seconds)
RATE_LIMIT_RETRY_DELAY=60

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# FastAPI host
HOST=0.0.0.0

# FastAPI port
PORT=8000

# Production cycle interval (minutes)
CYCLE_INTERVAL_MINUTES=30

# ============================================================================
# LOGGING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================================
# NOTES
# ============================================================================
# 1. Copy this file to .env and fill in your values
# 2. Never commit .env to version control
# 3. GEMINI_API_KEY is required - get it from: https://makersuite.google.com/app/apikey
# 4. Recommended model: 2.5-pro (most current, best quality)
# 5. Rate limits: Free tier has limits, adjust delays accordingly
