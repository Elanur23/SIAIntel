# --- 🤖 AI ENGINES (One is required, Groq preferred) ---
# Groq: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# Gemini: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- 🛰️ DISTRIBUTION NODES ---
# Discord Webhook: Settings -> Integrations -> Webhooks in your server
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Twitter/X API v2 (OAuth 1.0a): https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret

# --- ☁️ GOOGLE CLOUD INTEGRATION (PRO) ---
# Required for Indexing API, Text-to-Speech & Search Console
# Create a Service Account at https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_PROJECT_ID=your-project-id

# Google Indexing API (Optional - for priority indexing of breaking news)
# Same service account as above, requires Indexing API scope
# Enable at: https://console.cloud.google.com/apis/library/indexing.googleapis.com

# --- 🛡️ SECURITY & CONFIG ---
# Admin Password (REQUIRED for production)
# SECURITY REQUIREMENTS:
# - Minimum 16 characters (recommended: 32+)
# - Mix of uppercase, lowercase, numbers, special characters
# - Never commit actual password to git
# - Use different password for each environment
# Generate secure password: openssl rand -base64 32
ADMIN_SECRET=your-secure-admin-password-min-16-chars

# Session Secret (REQUIRED for production)
# Used for cryptographic session token generation
# SECURITY REQUIREMENTS:
# - Minimum 32 characters (recommended: 48+)
# - Must be different from ADMIN_SECRET
# - Never commit actual secret to git
# Generate secure secret: openssl rand -base64 48
SESSION_SECRET=your-session-secret-min-32-chars

# Node Environment (REQUIRED for production)
# Values: development | production | test
# IMPORTANT: Set to 'production' in production deployment
# Enables: Secure cookies, optimized builds, security headers
NODE_ENV=development

# Site URL (required for dynamic metadata & sitemaps)
NEXT_PUBLIC_SITE_URL=https://siaintel.com
NEXT_PUBLIC_BASE_URL=https://siaintel.com

# --- 📊 ANALYTICS & ADS ---
# Google AdSense
GOOGLE_ADSENSE_ID=ca-pub-xxxxxxxxxxxxxxxx
# Google Analytics 4
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# Google Tag Manager (Optional)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX


# ============================================
# DISTRIBUTION OS - FEATURE FLAGS (Phase 1)
# ============================================
DISTRIBUTION_ENABLED=false
DISTRIBUTION_PLATFORMS=
DISTRIBUTION_AUTO_PUBLISH=false
DISTRIBUTION_REVIEW_REQUIRED=true

# Platform API Keys (not used in Phase 1)
TWITTER_API_KEY=
LINKEDIN_CLIENT_ID=

# ============================================
# TELEGRAM PUBLISHING (Phase 3C - Sandbox Mode)
# ============================================
# Telegram Bot Token: Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Test Chat ID: Your test channel/group ID (use @userinfobot to get ID)
# Example: -1001234567890 (for channels/groups, starts with -100)
TELEGRAM_TEST_CHAT_ID=your_test_chat_id_here

# Production Chat ID: Your production channel/group ID (NOT USED YET)
# CRITICAL: Keep this different from TEST_CHAT_ID to prevent accidents
TELEGRAM_PRODUCTION_CHAT_ID=your_production_chat_id_here
