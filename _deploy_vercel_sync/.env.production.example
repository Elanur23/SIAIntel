TWITTER_HANDLE=@heynewsusa
INSTAGRAM_USERNAME=heynewsusa

# ============================================
# 🤖 AI CONFIGURATION (OPTIONAL)
# ============================================
# AI Scheduler settings
AI_SCHEDULER_ENABLED=true
AI_AUTO_PUBLISH=false
AI_QUALITY_THRESHOLD=7
AI_DAILY_QUOTA=50

# AI Model preferences
AI_MODEL_PREFERENCE=gpt-4-turbo
AI_IMAGE_MODEL=dall-e-3
AI_TEMPERATURE=0.7

# ============================================
# 🎬 AI VIDEO GENERATION (OPTIONAL)
# ============================================
# Configure one or more providers for video generation
# You only need the providers you want to use
# Cost comparison: Pictory ($0.77/min) < D-ID ($0.97/min) < Synthesia ($2.90/min)

# Synthesia - Professional news videos with avatars
# Get API key: https://www.synthesia.io/
# Best for: Professional broadcasts, high-quality news videos
# Cost: ~$2.90/minute | Processing: 5-10 min
SYNTHESIA_API_KEY=

# Pictory - Fast automated video creation
# Get API key: https://pictory.ai/
# Best for: Quick videos, automated content
# Cost: ~$0.77/minute | Processing: 3-5 min
PICTORY_API_KEY=

# D-ID - Realistic talking head videos
# Get API key: https://www.d-id.com/
# Best for: Realistic avatars, custom presenters
# Cost: ~$0.97/minute | Processing: 2-3 min
DID_API_KEY=

# ============================================
# 🔧 DEVELOPMENT SETTINGS (DO NOT USE IN PRODUCTION)
# ============================================
# NODE_ENV=production  # Automatically set by Vercel/hosting
# NEXT_PUBLIC_DEBUG=false


# ============================================
# 🚀 HIGH-PERFORMANCE INFRASTRUCTURE
# ============================================

# CDN Configuration (for 1M+ requests/second)
NEXT_PUBLIC_CDN_AUDIO_URL=https://cdn.siaintel.com/audio
NEXT_PUBLIC_CDN_IMAGES_URL=https://cdn.siaintel.com/images
NEXT_PUBLIC_CDN_STATIC_URL=https://cdn.siaintel.com/static
NEXT_PUBLIC_CDN_VIDEO_URL=https://cdn.siaintel.com/video

# Database Connection Pool
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_CONNECTION_TIMEOUT=5000
DB_IDLE_TIMEOUT=30000

# Read Replicas (for load balancing)
DB_READ_REPLICAS_ENABLED=true
DB_READ_REPLICAS=db-replica-1.siaintel.com,db-replica-2.siaintel.com,db-replica-3.siaintel.com

# Cache Revalidation Secret
REVALIDATION_SECRET=your-secret-key-here-change-in-production

# ISR Configuration
ISR_MEMORY_CACHE_SIZE=52428800
ISR_FLUSH_TO_DISK=true

# ============================================
# 🛡️ DEEP CYBER SHIELD (Zero Trust Security)
# ============================================

# Signed URL Secret (REQUIRED - change in production!)
# Generate with: openssl rand -base64 32
SIGNED_URL_SECRET=your-super-secret-key-min-32-chars

# Rate Limiting
RATE_LIMIT_WINDOW=60000
MAX_REQUESTS_PER_WINDOW=30

# Geographic Blocking
ENABLE_GEO_BLOCKING=true
ENABLE_OFAC_BLOCKING=true
