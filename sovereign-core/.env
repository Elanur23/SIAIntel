# SIAIntel API (Optional - for auto upload)
# SIAINTEL_API_URL=https://siaintel.com/api/upload
# SIAINTEL_API_KEY=your_api_key_here

# Cycle Interval (minutes)
CYCLE_INTERVAL=20
