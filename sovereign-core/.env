# Gemini API Key (Required)
GEMINI_API_KEY=AIzaSyAHVc9F9_G7xUmKK1T3egs7wvHOpER3VKQ

# Gemini Model Type (Optional)
# Options: 'pro' (gemini-1.5-pro), 'flash' (gemini-1.5-flash), '2.5-pro' (gemini-2.5-pro)
# Default: '2.5-pro'
