# ============================================
# SIA INTELLIGENCE - PRODUCTION ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local for development
# Configure these in Vercel Dashboard for production
# ============================================

# --- 🔐 NEXTAUTH & SESSION (CRITICAL - REQUIRED) ---
# NextAuth Secret: Used for JWT encryption and session management
# SECURITY: Generate with: openssl rand -base64 32
# MUST be at least 32 characters
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars-CHANGE-THIS

# NextAuth URL: Your production site URL
# CRITICAL: Must match your Vercel deployment URL
NEXTAUTH_URL=https://siaintel.com

# Session Secret: Additional session encryption layer
# SECURITY: Generate with: openssl rand -base64 48
# MUST be different from NEXTAUTH_SECRET
SESSION_SECRET=your-session-secret-min-48-chars-CHANGE-THIS

# --- 🗄️ DATABASE (CRITICAL - REQUIRED FOR PRODUCTION) ---
# Turso Database URL (Production - Recommended)
# Get from: https://turso.tech/
# Format: libsql://[database-name]-[org-name].turso.io
TURSO_DATABASE_URL=libsql://your-database-name.turso.io

# Turso Auth Token (Required if using Turso)
# Get from Turso dashboard
TURSO_AUTH_TOKEN=your-turso-auth-token

# Database URL (Fallback - SQLite for development only)
# Production MUST use Turso (above) or PostgreSQL
# Format for PostgreSQL: postgresql://user:password@host:5432/database?ssl=true
DATABASE_URL=file:./dev.db

# --- 🌐 SITE CONFIGURATION (REQUIRED) ---
# Your production site URL (used for metadata, sitemaps, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://siaintel.com
NEXT_PUBLIC_BASE_URL=https://siaintel.com

# Node Environment
# CRITICAL: Set to 'production' in Vercel
NODE_ENV=production

# --- 🔑 ADMIN & API KEYS (REQUIRED) ---
# Admin Password (for initial admin user creation)
# SECURITY: Minimum 16 characters, use strong password
# Generate with: openssl rand -base64 32
ADMIN_SECRET=your-secure-admin-password-min-16-chars-CHANGE-THIS

# AI API Keys (at least one required for content generation)
# Groq API (Recommended - Fast and reliable)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Gemini API (Alternative/Backup)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Internal API Key (for authenticated API routes)
AI_API_KEY=your-internal-api-key-CHANGE-THIS
NEXT_PUBLIC_AI_API_KEY=your-public-api-key-CHANGE-THIS

# Signed URL Secret (for secure URL generation)
SIGNED_URL_SECRET=your-signed-url-secret-CHANGE-THIS

# --- 📊 GOOGLE SERVICES (OPTIONAL BUT RECOMMENDED) ---
# Google Analytics 4
# Get from: https://analytics.google.com/
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Tag Manager (Optional)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google AdSense
# Get from: https://www.google.com/adsense/
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=ca-pub-xxxxxxxxxxxxxxxx
GOOGLE_ADSENSE_ID=ca-pub-xxxxxxxxxxxxxxxx

# Google Cloud Service Account (for Indexing API, TTS, etc.)
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_PROJECT_ID=your-google-project-id

# --- 📱 SOCIAL MEDIA & DISTRIBUTION (OPTIONAL) ---
# Twitter/X API v2 (OAuth 1.0a)
# Get from: https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret

# Discord Webhook
# Get from: Server Settings -> Integrations -> Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# Telegram Bot (for publishing)
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_TEST_CHAT_ID=your_test_chat_id_here
TELEGRAM_PRODUCTION_CHAT_ID=your_production_chat_id_here

# --- 🚀 DISTRIBUTION OS (OPTIONAL) ---
DISTRIBUTION_ENABLED=false
DISTRIBUTION_PLATFORMS=
DISTRIBUTION_AUTO_PUBLISH=false
DISTRIBUTION_REVIEW_REQUIRED=true

# --- 🔧 OPTIONAL SERVICES ---
# Redis (for caching and rate limiting - optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Idle Timeout (minutes)
IDLE_TIMEOUT_MINUTES=30

# ============================================
# CRITICAL PRODUCTION CHECKLIST
# ============================================
# ✅ NEXTAUTH_SECRET - Generate unique 32+ char secret
# ✅ NEXTAUTH_URL - Set to your production domain
# ✅ SESSION_SECRET - Generate unique 48+ char secret (different from NEXTAUTH_SECRET)
# ✅ TURSO_DATABASE_URL - Set up Turso database
# ✅ TURSO_AUTH_TOKEN - Get from Turso dashboard
# ✅ NEXT_PUBLIC_SITE_URL - Your production domain
# ✅ NODE_ENV=production - Critical for security
# ✅ ADMIN_SECRET - Strong password for admin access
# ✅ GROQ_API_KEY or GEMINI_API_KEY - At least one AI provider
# ✅ NEXT_PUBLIC_GA4_MEASUREMENT_ID - For analytics (recommended)
# ✅ GOOGLE_ADSENSE_ID - For monetization (optional)
#
# SECURITY NOTES:
# - Never commit actual secrets to git
# - Use different secrets for each environment
# - Rotate secrets regularly
# - Use strong, randomly generated values
# - Enable SSL/TLS for all database connections in production
